# Required
DATABASE_URL=postgres://bagradar:bagradar@postgres:5432/bagradar
TELEGRAM_BOT_TOKEN=<from @BotFather>
ANTHROPIC_API_KEY=<from console.anthropic.com>
AI_MODEL=claude-sonnet-4-6
HELIUS_API_KEY=<from helius.dev>
BAGS_API_KEY=<from bags.fm>
MASTER_WALLET_SEED=<64 hex chars = 32 bytes: openssl rand -hex 32>
WEBHOOK_SECRET=<random string: openssl rand -hex 16>

# Optional
GITHUB_TOKEN=<enables 5000 req/hr vs 60 req/hr>
WEBHOOK_PORT=8080
TEST_DATABASE_URL=postgres://bagradar:bagradar@localhost:5432/bagradar_test
